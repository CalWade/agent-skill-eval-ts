# OpenClaw EasyClaw Agent API（唯一入口，所有模型共用同一端点）
AGENT_API_URL=https://your-instance.openclaw.ai/v1/chat/completions
AGENT_API_KEY=your-api-key-here

# 平台特有参数（如有，作为 extra_body 传入）
AGENT_INSTANCE_ID=your-instance-id

# 额外请求参数（JSON 格式，可选）
# AGENT_EXTRA_BODY={"key":"value"}

# 运行参数
REQUEST_INTERVAL=3     # 用例间等待秒数（防限频，默认 3）
SWITCH_WAIT=2          # 切换模型后等待秒数（等平台确认，默认 2）
REQUEST_TIMEOUT=60     # 单次请求超时秒数（默认 60）

# 报告输出目录（默认 results）
# RESULTS_DIR=results
