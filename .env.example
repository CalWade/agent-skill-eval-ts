# ============================================================
# Agent Skill Eval — 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入你的值:
#   cp .env.example .env

# ── 必填：Agent API 配置 ──

# Agent 平台的 Chat Completions API 地址（必须兼容 OpenAI 格式）
AGENT_API_URL=

# Agent 平台的 API Key
AGENT_API_KEY=

# ── 可选：Agent 平台参数 ──

# 模型名称
# AGENT_MODEL=gpt-4o

# 平台特定的额外参数（JSON 格式，合并到请求体）
# AGENT_EXTRA_BODY={"instance_id":"i-xxx"}

# Trace 适配器（openai | openclaw | none）
# TRACE_ADAPTER=none

# ── 可选：LLM 裁判 ──

# JUDGE_API_URL=https://api.deepseek.com/v1/chat/completions
# JUDGE_API_KEY=sk-xxx
# JUDGE_MODEL=deepseek-chat

# ── 可选：运行参数 ──

# REQUEST_INTERVAL=3
# MAX_RETRIES=2
# RESULTS_DIR=results
