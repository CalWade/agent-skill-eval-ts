{
  "name": "agent-skill-eval",
  "version": "0.2.0",
  "description": "AI Agent 技能质量评估框架（TypeScript）",
  "type": "module",
  "scripts": {
    "eval": "tsx src/cli.ts",
    "smoke": "tsx src/cli.ts --suite examples/openclaw-feishu/test-cases/safe-smoke.yaml",
    "smoke:dry": "tsx src/cli.ts --suite examples/openclaw-feishu/test-cases/safe-smoke.yaml --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "keywords": ["agent", "eval", "llm", "testing"],
  "author": "Calvin Wei",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "eventsource-parser": "^3.0.6",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
